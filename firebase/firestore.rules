rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isBuyer() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'BUYER';
    }

    function isLeader() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'LEADER';
    }

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read, update: if isOwner(uid);
      allow delete: if false;
    }

    match /cooperatives/{cooperativeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /cooperatives/{cooperativeId}/products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isLeader() &&
        request.resource.data.cooperativeId == cooperativeId;
    }

    match /orders/{orderId} {
      allow create: if isBuyer() &&
        request.resource.data.buyerUid == request.auth.uid;
      allow read: if isSignedIn() && (
        resource.data.buyerUid == request.auth.uid || isLeader()
      );
      allow update: if isLeader() || (
        isBuyer() && resource.data.buyerUid == request.auth.uid
      );
      allow delete: if false;
    }
  }
}
